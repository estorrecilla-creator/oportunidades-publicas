    "express-rate-limit": "6.7.0",
    "helmet": "7.0.0",
    "compression": "1.7.4",
    "validator": "13.9.0",
    "nodemailer": "6.9.3",
    "speakeasy": "2.0.0",
    "qrcode": "1.5.3",
    "redis": "4.6.5"
  },
  "devDependencies": {
    "nodemon": "3.0.1",
    "jest": "29.7.0",
    "supertest": "6.3.3",
    "eslint": "8.40.0"
