{
  "name": "oportunidades-publicas",
  "version": "3.0.0",
  "description": "Plataforma profesional de licitaciones públicas",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config jest.e2e.config.js",
